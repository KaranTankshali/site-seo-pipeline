{
  "name": "site-seo-pipeline",
  "version": "0.1.0",
  "description": "Sitemap-driven SEO pipeline: crawl pages, Google Suggest + SerpAPI SERP research, Gemini meta and below-the-fold suggestions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "site-seo-pipeline": "./dist/cli.js"
  },
  "files": [
    "dist",
    "AGENTS.md",
    "CLAUDE.md",
    "CONTRIBUTING.md",
    "GEMINI.md",
    ".clinerules"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "cli": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "seo",
    "sitemap",
    "serp",
    "serpapi",
    "meta-tags",
    "crawler",
    "playwright",
    "gemini"
  ],
  "author": "Karan Tankshali",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "playwright": "^1.59.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "playwright": "^1.59.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}

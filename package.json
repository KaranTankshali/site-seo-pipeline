{
  "name": "site-seo-pipeline",
  "version": "0.1.0",
  "description": "Sitemap-driven SEO pipeline: crawl pages, Google Suggest + SerpAPI SERP research, Gemini meta and below-the-fold suggestions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "site-seo-pipeline": "./dist/cli.js"
  },
  "files": [
    "dist",
    "AGENTS.md",
    "CLAUDE.md",
    "CONTRIBUTING.md",
    "GEMINI.md",
    ".clinerules"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "cli": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "seo",
    "sitemap",
    "serp",
    "serpapi",
    "meta-tags",
    "crawler",
    "playwright",
    "gemini"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "playwright": "^1.40.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@vitest/coverage-v8": "^3.0.5",
    "playwright": "^1.40.0",
    "typescript": "^5.3.3",
    "vitest": "^3.0.5"
  }
}
